#!/usr/bin/env sh
# paper-trading-terminal installer (macOS / Linux)
# Usage: curl -sSL https://github.com/<owner>/paper-trading-terminal/raw/main/install | sh

set -eu

type curl >/dev/null 2>&1 || { echo "curl: not found"; exit 1; }

repo="${PAPER_INSTALL_REPO:-tsui66/paper-trading-terminal}"
bin_name='paper'
package_name='paper-trading-terminal'

get_latest_release() {
  url=$(curl --silent -o /dev/null -w "%{url_effective}" -L "https://github.com/$repo/releases/latest")
  tag=$(echo "$url" | sed -E 's|.*/tag/||')
  if [ -z "$tag" ] || [ "$tag" = "$url" ]; then
    echo "Failed to fetch the latest release. Redirect URL: $url" >&2
    return 1
  fi
  echo "$tag"
}

version="${PAPER_INSTALL_VERSION:-}"
if [ -z "$version" ]; then
  version=$(get_latest_release) || exit 1
fi

echo "Installing $package_name@$version"

platform="$(uname | tr '[:upper:]' '[:lower:]')"
arch="$(uname -m)"

case "$arch" in
  x86_64) arch="amd64" ;;
  aarch64 | arm64) arch="arm64" ;;
esac

# Prefer musl on Linux when published (static, portable across glibc versions).
libc=''
if [ "$platform" = "linux" ] && [ -z "${PAPER_INSTALL_GNU:-}" ]; then
  libc='-musl'
fi

artifact="$package_name-$platform$libc-$arch.tar.gz"
download_url="https://github.com/$repo/releases/download/$version/$artifact"

tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT

if [ -n "${PAPER_INSTALL_FROM:-}" ]; then
  echo "Using local package: $PAPER_INSTALL_FROM"
  cp "$PAPER_INSTALL_FROM" "$tmp_dir/$bin_name.tar.gz"
else
  echo "Downloading $download_url"
  if ! curl -fsSL -o "$tmp_dir/$bin_name.tar.gz" "$download_url"; then
    if [ "$platform" = "linux" ] && [ -n "$libc" ]; then
      echo "musl build not found, retrying gnu build..."
      artifact="$package_name-$platform-$arch.tar.gz"
      download_url="https://github.com/$repo/releases/download/$version/$artifact"
      echo "Downloading $download_url"
      curl -fsSL -o "$tmp_dir/$bin_name.tar.gz" "$download_url"
    else
      exit 1
    fi
  fi
fi

tar zxf "$tmp_dir/$bin_name.tar.gz" -C "$tmp_dir"

# Install target (no sudo by default — agent-friendly for OpenClaw / CI):
#   default     → $HOME/.local/bin
#   PAPER_INSTALL_DIR=/path  → explicit directory (must be user-writable)
#   PAPER_INSTALL_SYSTEM=1   → /usr/local/bin (uses sudo when not root)
if [ -n "${PAPER_INSTALL_DIR:-}" ]; then
  install_dir="$PAPER_INSTALL_DIR"
elif [ "${PAPER_INSTALL_SYSTEM:-}" = "1" ]; then
  install_dir=/usr/local/bin
else
  install_dir="${HOME}/.local/bin"
fi

install_bin() {
  dest_dir=$1
  mkdir -p "$dest_dir"
  mv "$tmp_dir/$bin_name" "$dest_dir/$bin_name"
  chmod +x "$dest_dir/$bin_name"
}

case "$install_dir" in
  /usr/local/bin)
    if [ "$(id -u)" -eq 0 ]; then
      install_bin "$install_dir"
    else
      sudo mkdir -p "$install_dir"
      sudo mv "$tmp_dir/$bin_name" "$install_dir/$bin_name"
      sudo chmod +x "$install_dir/$bin_name"
    fi
    ;;
  *)
    install_bin "$install_dir"
    ;;
esac

dest="$install_dir/$bin_name"

echo ""
echo "paper CLI $version installed to $dest"

case ":$PATH:" in
  *:"$install_dir":*) ;;
  *)
    echo ""
    echo "Add to PATH for this shell:"
    echo "  export PATH=\"$install_dir:\$PATH\""
    echo ""
    echo "Persist (zsh): echo 'export PATH=\"$install_dir:\$PATH\"' >> ~/.zshrc"
    echo "Persist (bash): echo 'export PATH=\"$install_dir:\$PATH\"' >> ~/.bashrc"
    ;;
esac
echo ""
echo "Next steps:"
echo "  paper -h                      # verify install"
echo "  paper config provider-status  # check yahoo (primary) + fcontext (optional)"
echo "  paper quote AAPL              # test live quote"
echo "  paper tui                     # launch dashboard"
echo ""
echo "Optional — fcontext fallback when Yahoo is down:"
echo "  curl -sSL https://github.com/aitaport/fcontext-cli/releases/latest/download/install.sh | sh"
echo "  fcontext auth login"
echo "  paper config provider-status"
echo ""